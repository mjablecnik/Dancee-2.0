# =============================================================================
# Directus - Local Docker Configuration
# =============================================================================
# Copy to .env and fill in all values before running.

# --- Database (Supabase PostgreSQL) ---
DB_CLIENT=pg
DB_CONNECTION_STRING=postgresql://<DB_USER>:<DB_PASSWORD>@<SUPABASE_HOST>:6543/postgres
DB_SSL__REJECT_UNAUTHORIZED=false

DB_POOL__MIN=0
DB_POOL__MAX=5

# --- Security ---
# Min 32 characters. Generate with: openssl rand -base64 32
SECRET=<GENERATED_SECRET>

# --- Admin Account (created on first bootstrap) ---
ADMIN_EMAIL=<ADMIN_EMAIL>
ADMIN_PASSWORD=<ADMIN_PASSWORD>

# --- Server ---
PORT=8055
PUBLIC_URL=http://localhost:8055

# --- Storage (Supabase S3) ---
STORAGE_LOCATIONS=supabase
STORAGE_SUPABASE_DRIVER=s3
STORAGE_SUPABASE_KEY=<SUPABASE_S3_KEY>
STORAGE_SUPABASE_SECRET=<SUPABASE_S3_SECRET>
STORAGE_SUPABASE_BUCKET=directus-files
STORAGE_SUPABASE_REGION=eu-west-1
STORAGE_SUPABASE_ENDPOINT=https://<SUPABASE_PROJECT_ID>.storage.supabase.co/storage/v1/s3
STORAGE_SUPABASE_FORCE_PATH_STYLE=true

# --- Optional: Redis ---
# REDIS_HOST=<REDIS_HOST>
# REDIS_PORT=6379
# REDIS_PASSWORD=<REDIS_PASSWORD>

# --- Optional: Email ---
# EMAIL_FROM=no-reply@example.com
# EMAIL_TRANSPORT=smtp
# EMAIL_SMTP_HOST=<SMTP_HOST>
# EMAIL_SMTP_PORT=587
# EMAIL_SMTP_USER=<SMTP_USER>
# EMAIL_SMTP_PASSWORD=<SMTP_PASSWORD>
