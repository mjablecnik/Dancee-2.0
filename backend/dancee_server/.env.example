# Server Configuration
PORT=3001

# Environment
NODE_ENV=development

# Swagger Documentation Authentication (Production only)
# Change these values in production!
SWAGGER_USER=admin
SWAGGER_PASSWORD=changeme

# Firebase Configuration
# Option 1: Path to service account file (for local development)
# Example: ./secrets/serviceAccountKey.json (relative path)
# Example: /absolute/path/to/serviceAccountKey.json (absolute path)
FIREBASE_SERVICE_ACCOUNT_PATH=./secrets/serviceAccountKey.json

# Option 2: Service account JSON as string (for Fly.io, Cloud Run, etc.)
# Set this on Fly.io with: fly secrets set FIREBASE_SERVICE_ACCOUNT_JSON="$(cat secrets/serviceAccountKey.json)"
# Leave empty for local development
FIREBASE_SERVICE_ACCOUNT_JSON=

# Note: If FIREBASE_SERVICE_ACCOUNT_JSON is set, it takes priority over FIREBASE_SERVICE_ACCOUNT_PATH
# If both are empty, uses application default credentials
